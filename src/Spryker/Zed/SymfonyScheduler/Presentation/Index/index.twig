{% extends '@Gui/Layout/layout.twig' %}

{% set widget_title = 'Scheduled Tasks' %}

{% block head_title widget_title | trans %}

{% block content %}
    {% embed '@Gui/Partials/widget.twig' with { widget_title: widget_title | trans } %}
        {% block widget_content %}
            <table class="table table-striped table-bordered table-hover gui-table-data">
                <thead>
                    <tr>
                        <th>{{ 'Name' | trans }}</th>
                        <th>{{ 'Command' | trans }}</th>
                        <th>{{ 'Schedule' | trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for task in tasks %}
                        <tr>
                            <td>{{ task.name }}</td>
                            <td>{{ task.command }}</td>
                            <td>{{ task.schedule }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3">{{ 'No scheduled tasks configured.' | trans }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endblock %}
    {% endembed %}
{% endblock %}
